# ===== Copie este arquivo para ".env.local" e preencha os valores =====
# (Na Vercel, esses valores entram em Settings > Environment Variables)

# --- Login do Kick (criado em https://dev.kick.com) ---
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# URL pública do seu site + /api/auth/callback
# Ex.: https://minha-loja.vercel.app/api/auth/callback
KICK_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Sessão (qualquer texto longo e aleatório, mínimo 32 caracteres) ---
SESSION_SECRET=troque-isto-por-um-texto-bem-grande-e-aleatorio

# --- Kicklet (motor de pontos) ---
# Token criado em https://kicklet.app/profile/settings
KICKLET_API_TOKEN=
# Seu ID numérico de canal no Kick (veja o guia de deploy)
KICKLET_CHANNEL_ID=

# --- Notificação de resgates (opcional, mas recomendado) ---
# Webhook de um canal do seu Discord para receber avisos de cada resgate
DISCORD_WEBHOOK_URL=

# --- Senha do painel admin (/admin) ---
ADMIN_PASSWORD=troque-esta-senha

# --- Banco de dados Upstash Redis (opcional) ---
# Necessário para histórico de resgates e entrega automática de códigos.
# Sem isto o site funciona, mas sem histórico e sem códigos automáticos.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
